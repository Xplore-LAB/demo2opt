# -----------------------------
# Direct LLM settings
# -----------------------------
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat

# -----------------------------
# External knowledge retrieval (Dify)
# Single runtime mode: datasets_retrieve
# -----------------------------
DIFY_API_URL=http://localhost/v1
DIFY_DATASETS_API_URL=http://localhost/v1
DIFY_API_KEY=dataset-xxxxxxxxxxxxxxxxxxxx

# Optional fixed dataset id.
# If empty, the service will auto-discover via GET /datasets once at startup,
# cache the selected id for the current run, then use POST /datasets/{id}/retrieve.
DIFY_DATASET_ID=
DIFY_RETRIEVAL_API_MODE=datasets_retrieve

# Dataset discovery options (used only when auto-discovering dataset_id)
DIFY_DATASETS_KEYWORD=
DIFY_DATASETS_TAG_IDS=
DIFY_DATASETS_PAGE=1
DIFY_DATASETS_LIMIT=20
DIFY_DATASETS_INCLUDE_ALL=false

# Retrieve model options
DIFY_RETRIEVE_TOP_K=5
DIFY_RETRIEVE_SEARCH_METHOD=semantic_search
DIFY_RETRIEVE_RERANKING_ENABLE=false
DIFY_RETRIEVE_SCORE_THRESHOLD=0

# Optional user id (for custom integrations)
DIFY_USER=abc-123

# -----------------------------
# Runtime
# -----------------------------
DATA_FILE=./data/demo.xlsx
ENABLE_CLOSED_LOOP_VALIDATION=false
LLM_TIMEOUT_SEC=120
LLM_RETRY_MAX=3
LLM_RETRY_BACKOFF_SEC=0.5
LLM_RETRY_JITTER_SEC=0.2
LLM_RETRY_MULTIPLIER=2.0
SEMANTICS_CONFIG_PATH=config/indicators.yaml
